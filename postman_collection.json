{
  "info": {
    "name": "Gear Rental API",
    "_postman_id": "gear-rental-api",
    "description": "Complete API collection for the Gear Rental platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost/api", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"secret123\",\n  \"password_confirm\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('access_token', res.access);",
                  "pm.collectionVariables.set('refresh_token', res.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/token/refresh/", "host": ["{{base_url}}"], "path": ["auth", "token", "refresh", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/auth/logout/", "host": ["{{base_url}}"], "path": ["auth", "logout", ""] },
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
    {
      "name": "Equipment",
      "item": [
        {
          "name": "List Equipment",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/equipment/", "host": ["{{base_url}}"], "path": ["equipment", ""] }
          }
        },
        {
          "name": "List Equipment – Filter by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/equipment/?category=cameras",
              "host": ["{{base_url}}"],
              "path": ["equipment", ""],
              "query": [{ "key": "category", "value": "cameras" }]
            }
          }
        },
        {
          "name": "List Equipment – Filter by Price",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/equipment/?min_price=10000&max_price=50000",
              "host": ["{{base_url}}"],
              "path": ["equipment", ""],
              "query": [
                { "key": "min_price", "value": "10000" },
                { "key": "max_price", "value": "50000" }
              ]
            }
          }
        },
        {
          "name": "List Equipment – Available Only",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/equipment/?is_available=true",
              "host": ["{{base_url}}"],
              "path": ["equipment", ""],
              "query": [{ "key": "is_available", "value": "true" }]
            }
          }
        },
        {
          "name": "Get Equipment Detail",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/equipment/1/", "host": ["{{base_url}}"], "path": ["equipment", "1", ""] }
          }
        },
        {
          "name": "Create Equipment (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/equipment/", "host": ["{{base_url}}"], "path": ["equipment", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sony A7 IV\",\n  \"description\": \"Full-frame mirrorless camera\",\n  \"category\": 1,\n  \"daily_rate\": \"25000.00\",\n  \"is_available\": true\n}"
            }
          }
        },
        {
          "name": "Update Equipment (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/equipment/1/", "host": ["{{base_url}}"], "path": ["equipment", "1", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sony A7 IV\",\n  \"description\": \"Updated description\",\n  \"category\": 1,\n  \"daily_rate\": \"27000.00\",\n  \"is_available\": true\n}"
            }
          }
        },
        {
          "name": "Partial Update Equipment (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/equipment/1/", "host": ["{{base_url}}"], "path": ["equipment", "1", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_available\": false\n}"
            }
          }
        },
        {
          "name": "Delete Equipment (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/equipment/1/", "host": ["{{base_url}}"], "path": ["equipment", "1", ""] }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "List My Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/bookings/", "host": ["{{base_url}}"], "path": ["bookings", ""] }
          }
        },
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/bookings/", "host": ["{{base_url}}"], "path": ["bookings", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"equipment\": 1,\n  \"start_date\": \"2026-05-01\",\n  \"end_date\": \"2026-05-05\"\n}"
            }
          }
        },
        {
          "name": "Check Availability",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/bookings/check-availability/", "host": ["{{base_url}}"], "path": ["bookings", "check-availability", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"equipment_id\": 1,\n  \"start_date\": \"2026-05-01\",\n  \"end_date\": \"2026-05-05\"\n}"
            }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/bookings/1/cancel/", "host": ["{{base_url}}"], "path": ["bookings", "1", "cancel", ""] }
          }
        }
      ]
    }
  ]
}
